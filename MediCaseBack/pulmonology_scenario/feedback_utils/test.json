{'total': {'strengths': 'شما در مورد وضعیت بیمار سوالات خیلی خوبی پرسیدید. به خصوص در مورد تنگی نفس و سابقه بیماری های خانوادگی، سوالات مناسبی مطرح کردید که به تشخیص بهتر کمک می کند. پرسش شما در مورد علائم تنفسی و سابقه ی بیماری های قلبی بسیار مهم بود.', 'weaknesses': {'M': 'شما در پرسش های خود، به موارد مهمی مانند سابقه سکته قلبی در خانواده توجه نکردید که می توانست به شما در ارزیابی ریسک بیشتر کمک کند. همچنین به برخی از سوالات در مورد علائم تنفسی (مثل سرفه و حساسیت) که می توانستند اطلاعات بیشتری به شما بدهند، پاسخ ندادید.', 'E': 'شما برخی سوالات غیرضروری را نیز پرسیدید، به ویژه در مورد سابقه استفاده از مواد مخدر که به این شرایط خاص مربوط نمی\u200cشود و نمی\u200cتوانسته به تشخیص کمک کند.'}, 'educational_feedback': 'بهتر است اولویت پرسش های مربوط به علائم مهم همچون تنگی نفس، سرفه و سابقه بیماری های قلبی را در نظر بگیرید. همچنین در طول مصاحبه توجه کنید تا به حداقل 50% سوالات بهینه برسید تا بتوانید به مرحله بعدی به درستی منتقل شوید.'}, 'history_taking': {'strengths': {'present_illness': {'level_of_consciousness': 'شما سوالات مربوط به تنگی نفس و سرفه را به خوبی مطرح کردید، که از جمله سوالات کلیدی است.'}, 'medical_history': {'question1': {'question1a': 'شما پرسیدید که آیا بیمار سابقه بیماری های مزمن دارد؟ که این اطلاعات کمک کننده است.'}}}, 'weaknesses': {'M': {'question1': {'question1a': 'نبود سوال در مورد سابقه سکته قلبی در خانواده، عدم بررسی مهمی است.'}, 'question4': 'سؤال در مورد سرفه و حجم خلط می\u200cتوانسته بهتر باشد.'}, 'E': {}, 'educational_feedback': 'بهتر است هر مرحله را با دقت بیشتری پیش ببرید و برای ابتدای بررسی سوالات کلیدی مربوط به علائم و سوابق بیماری را به یاد داشته باشید.'}, 'physical_exam': {'strengths': {'B': {'cumulative': 4, 'meaning': 'شما به بررسی اولیه خوب از نظر وضعیت عمومی بیمار و نشانه\u200cهای حیاتی پرداخته\u200cاید.'}, 'C': {'adventitious_sounds': 'شما به صداهای غیرعادی تنفسی به ویژه ویزینگ توجه کردید که علامتی کلیدی برای بیماری\u200cهای تنفسی است.'}}, 'weaknesses': {'M': {'general_appearance': {'level_of_consciousness': 'باید به وضعیت هوشیاری بیمار در انتخاب سوالات توجه بیشتری می\u200cکردید.'}, 'E': {}}, 'educational_feedback': 'بسیار مهم است که درصد بالایی از سوالات بهینه دنبال شود. به بررسی وضعیت عمومی بیمار و علایم حیاتی توجه داشته باشید تا در تشخیص بهبود یابید.'}, 'paraclinic': {'strengths': {'C': {'cumulative': 6, 'meaning': 'شما تست\u200cهای مربوط به وضعیت تنفسی و آزمایش\u200cهای پایه را با دقت انتخاب کردید.'}, 'basic_blood_tests': {'CBC': 'شما تست\u200cهای خونی مربوط به ارزیابی وضعیت عمومی بیمار و التهاب را درخواست کردید می\u200c تواند به تشخیص بهتر کمک کند.'}}, 'weaknesses': {'M': {'VBG': 'آزمایش VBG به خوبی انجام نشد که باید تحت بررسی قرار گیرد.'}, 'E': {}, 'educational_feedback': 'توجه بیشتر به مراحل آزمایش ها و انتخاب تست های مناسب می تواند روند تشخیص را سریعتر و دقیق تر کند.'}, 'differential_diagnosis': {'strengths': 'شما به درستی بیماری های COPD و PTE را به عنوان تشخیص های دیفرانسیل اصلی شناسایی کردید که قابل توجه است.', 'weaknesses': {'M': 'برخی از بیماری\u200cها مثل بیماری\u200cهای قلبی و ریوی دیگر را در نظر نگرفتید و در انتخاب آنها خساست نشان دادید.', 'E': {}, 'educational_feedback': 'در ارزیابی بیماری\u200cها اطمینان حاصل کنید که همه گزینه\u200cهای ممکن به طور کامل بررسی شوند.'}, 'transition': {'transition_1_to_2': {'error': True, 'message': 'شما زودتر از کاملا از معرفی به مرحله معاینه فیزیکی وارد شدید.'}, 'transition_2_to_3': {'error': True, 'message': 'در مرحله معاینه فیزیکی، شما حداقل 50% سوالات بهینه را نپرسیدید.'}}}}}}}, {'history_taking': {'C': 6, 'E': 0, 'M': 20, 'O': 26, 'A': 6, 'Success_Rate_C_div_O': '23.08%', 'C_items': ['present_illness.question8', 'present_illness.question3', 'present_illness.question1', 'medical_history.question3', 'medical_history.question1.question1a', 'medical_history.question1.question1b'], 'E_items': [], 'M_items': ['family_history.question2', 'family_history.question1.question1a', 'family_history.question1.question1b', 'family_history.question3.question3a', 'family_history.question3.question3b', 'social_history.question1.question1a', 'social_history